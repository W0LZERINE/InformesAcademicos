# ============================================
# Entorno virtual de Python (NO SUBIR NUNCA)
# ============================================
venv/
env/
.env/
.venv/

# ============================================
# Archivos que genera Python al ejecutarse
# ============================================
__pycache__/
*.py[cod]
*.pyo
*.so
.Python

# ============================================
# PDFs generados por el programa
# ============================================
output/
*.pdf
temp_*.png

# ============================================
# Carpeta de distribución (se genera al compilar)
# ============================================
dist/
build/
*.exe
*.spec

# ============================================
# Configuraciones de editores de código
# ============================================
.vscode/
.idea/
*.swp
*.swo

# ============================================
# Archivos del sistema operativo
# ============================================
.DS_Store
Thumbs.db

# ============================================
# Archivos sensibles
# ============================================
.env
*.secret
